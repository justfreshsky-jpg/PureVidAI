# PureImage AI – Environment Variables Template
# Copy this file to .env and fill in your values.
# Never commit the .env file to version control.

# ── Image Providers ─────────────────────────────────────────
# Primary: fal.ai (https://fal.ai)
FAL_KEY=your-fal-api-key

# Secondary: Hugging Face (https://huggingface.co)
HF_KEY=your-huggingface-api-key

# Tertiary: Stability AI (https://stability.ai)
STABILITY_KEY=your-stability-api-key

# Quaternary: Replicate (https://replicate.com)
REPLICATE_KEY=your-replicate-api-key

# Pollinations.ai is free and needs no key - used as final fallback

# ── Text LLM (for prompt enhancement, optional) ─────────────
GROQ_KEY=your-groq-api-key
CEREBRAS_KEY=your-cerebras-api-key
GEMINI_KEY=your-gemini-api-key
COHERE_KEY=your-cohere-api-key
MISTRAL_KEY=your-mistral-api-key
OPENROUTER_KEY=your-openrouter-api-key

# ── App Config ───────────────────────────────────────────────
PORT=8080
