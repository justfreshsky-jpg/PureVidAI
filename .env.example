# PureVid AI – Environment Variables Template
# Copy this file to .env and fill in your values.
# Never commit the .env file to version control.

# ── Google Cloud / Vertex AI ────────────────────────────────
VERTEX_PROJECT_ID=your-gcp-project-id
VERTEX_LOCATION=us-central1
VERTEX_MODEL=gemini-1.5-flash
VERTEX_VIDEO_MODEL=veo-2.0-generate-001

# ── Video Provider ──────────────────────────────────────────
# Options: google | fal
VIDEO_PROVIDER=google

# ── fal.ai (CogVideoX) ─────────────────────────────────────
FAL_KEY=your-fal-api-key

# ── Text LLM provider keys (fallback chain) ─────────────────
# Chain order: Groq → Cerebras → Gemini → Cohere → Mistral → OpenRouter → HuggingFace
GROQ_KEY=your-groq-api-key
CEREBRAS_KEY=your-cerebras-api-key
GEMINI_KEY=your-gemini-api-key
COHERE_KEY=your-cohere-api-key
MISTRAL_KEY=your-mistral-api-key
OPENROUTER_KEY=your-openrouter-api-key
HF_KEY=your-huggingface-api-key

# ── Feature flags ───────────────────────────────────────────
# Set to "true" to fall back to fal.ai when Google video fails
ALLOW_FAL_FALLBACK=false
